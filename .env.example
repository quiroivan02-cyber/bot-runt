SHEET_NAME=Consultas RUNT
GOOGLE_CREDENTIALS_FILE=credentials.json
DEBUG_DIR=debug
HEADLESS=false

# Necesaria para extraer datos desde capturas con Groq Vision.
GROQ_API_KEY=

# Por defecto el CAPTCHA se ingresa manualmente.
# Cambiar esto puede incumplir condiciones de uso del sitio consultado.
ENABLE_GROQ_CAPTCHA=false

